# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/okta_sso

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-secret

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-another-long-random-secret
JWT_EXPIRES_IN=8h

# ─── SAML / Okta ──────────────────────────────────────────────────────────────
# Your Okta org domain (no trailing slash)
OKTA_DOMAIN=https://your-org.okta.com

# The SAML Entry Point URL (from Okta app → Sign On → View Setup Instructions)
SAML_ENTRY_POINT=https://your-org.okta.com/app/your-app-id/sso/saml

# Entity ID / Issuer (must match what you set in Okta → SP Entity ID)
SAML_ISSUER=http://localhost:4000/auth/saml/metadata

# ACS URL — where Okta POSTs the SAML response (must match Okta → ACS URL)
SAML_CALLBACK_URL=http://localhost:4000/auth/saml/callback

# PEM-encoded X.509 certificate from Okta (no header/footer, single line or multiline)
# Get it from: Okta app → Sign On → SAML Signing Certificates → Download certificate
SAML_CERT=MIIDpDCCAoygAwIBAgIGAX...paste-full-cert-here...

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Cookie ───────────────────────────────────────────────────────────────────
# Set to 'true' in production (requires HTTPS)
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
